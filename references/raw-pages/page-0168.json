{"data": {"__GLOBAL": {"_ATTACH_BASE_VIEW": "img.nga.178.com/attachments"}, "__U": {"150058": {"uid": 150058, "username": "UID:150058", "credit": 135537218, "medal": "272,207,157,92", "reputation": "28_30,61_0,147_775,130_10", "groupid": -1, "memberid": 73, "avatar": null, "yz": 4, "site": null, "honor": null, "regdate": 1123989606, "mute_time": null, "postnum": 41231, "rvrc": 29, "money": 90765, "thisvisit": 1782806849, "signature": null, "nickname": null, "bit_data": 135537218, "buffs": {"131": [[1618226, 131, 20698560, 150058, 1782779225, 1783038425, 7, 0]]}}, "66989363": {"uid": 66989363, "username": "UID:66989363", "credit": 135275008, "medal": null, "reputation": "147_-300", "groupid": -1, "memberid": 39, "avatar": null, "yz": 4, "site": null, "honor": null, "regdate": 1762774156, "mute_time": null, "postnum": 2753, "rvrc": 10, "money": 0, "thisvisit": 1782774028, "signature": null, "nickname": null, "bit_data": 135275008}, "__GROUPS": {"73": ["学徒", 360672, 73], "39": ["学徒", 98528, 39]}, "__MEDALS": {"272": ["272.gif", "棒棒糖", "叔叔请你吃棒棒糖", 272], "207": ["207.gif", "爆竹声中旧岁除", "一支红杏出墙来", 207], "157": ["157.gif", "王者之剑", "王者之剑活动纪念", 157], "92": ["92.gif", "小心死亡之翼-", "2011年大灾变开服纪念", 92]}, "__REPUTATIONS": {"147": {"150058": 775, "66989363": -300, "0": "大时代"}}}, "__R": [{"pid": 872146479, "fid": 706, "tid": 45974302, "authorid": 150058, "type": 0, "score": 55, "score_2": 0, "recommend": 0, "postdate": "2026-06-18 13:15", "subject": "", "alterinfo": "", "content": "[quote][pid=872146315,45974302,7618]Reply[/pid] [b]Post by [uid=37568353]异乡猫[/uid] (2026-06-18 13:14):[/b]<br/><br/>就让微盘缓半天吗，这样是不是不太好[s:a2:偷吃][/quote]<br/>他们自己不争气啊 都给时间和空间了。", "lou": 3340, "content_length": 39, "reply_to": 872146315, "from_client": "0 /", "postdatetimestamp": 1781759736}, {"pid": 872147002, "fid": 706, "tid": 45974302, "authorid": 150058, "type": 0, "score": 113, "score_2": 0, "recommend": 0, "postdate": "2026-06-18 13:20", "subject": "", "alterinfo": "", "content": "你们够了啊  目前3000家下跌", "lou